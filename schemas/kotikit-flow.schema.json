{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kotikit.dev/schemas/kotikit-flow.schema.json",
  "title": "Kotikit Flow Definition",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "number",
      "const": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "stateSchema": {
      "type": "string",
      "const": "KotikitGraphState/v1"
    },
    "requiredCapabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "nodes": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "uses": {
            "type": "string",
            "minLength": 1
          },
          "params": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          },
          "interrupt": {
            "type": "string",
            "enum": ["ask-user", "external-action"]
          }
        },
        "required": ["id", "uses"],
        "additionalProperties": false
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "minItems": 2,
        "maxItems": 2,
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "start": {
      "type": "string",
      "minLength": 1
    },
    "end": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "safetyProfile": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "schemaVersion",
    "id",
    "version",
    "title",
    "stateSchema",
    "requiredCapabilities",
    "nodes",
    "edges",
    "start",
    "end",
    "safetyProfile"
  ],
  "additionalProperties": false
}
