{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kotikit.dev/schemas/kotikit-artifact.schema.json",
  "title": "Kotikit Artifact",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": [
        "design-brief",
        "screen-model",
        "flow-model",
        "design-system-fit-report",
        "figma-target",
        "ui-composition-contract",
        "layout-contract",
        "variable-binding-plan",
        "draft-component-plan",
        "draft-plan",
        "figma-apply-packet",
        "figma-apply-report",
        "ui-quality-gate-report",
        "review-session",
        "revision-plan",
        "design-memory-candidate"
      ]
    },
    "schemaVersion": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "minLength": 1
    },
    "updatedAt": {
      "type": "string",
      "minLength": 1
    },
    "sourceNode": {
      "type": "object",
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["key", "version"],
      "additionalProperties": false
    },
    "payload": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "schemaVersion": {
              "type": "string",
              "const": "UICompositionContract/v1"
            },
            "parts": {
              "minItems": 1,
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "role": {
                    "type": "string",
                    "minLength": 1
                  },
                  "source": {
                    "type": "string",
                    "enum": ["existing-component", "draft-component", "approved-primitive"]
                  },
                  "componentKey": {
                    "type": "string",
                    "minLength": 1
                  },
                  "draftComponentId": {
                    "type": "string",
                    "minLength": 1
                  },
                  "primitiveReason": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": ["id", "name", "role", "source"],
                "additionalProperties": false
              }
            },
            "notes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "required": ["schemaVersion", "parts"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "schemaVersion": {
              "type": "string",
              "const": "LayoutContract/v1"
            },
            "strategy": {
              "type": "string",
              "enum": ["auto-layout", "grid", "mixed"]
            },
            "frames": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "parentId": {
                    "type": "string",
                    "minLength": 1
                  },
                  "mode": {
                    "type": "string",
                    "enum": ["auto-layout", "grid"]
                  },
                  "direction": {
                    "type": "string",
                    "enum": ["vertical", "horizontal"]
                  },
                  "sizing": {
                    "type": "string",
                    "enum": ["fixed", "hug", "fill"]
                  },
                  "spacingToken": {
                    "type": "string",
                    "minLength": 1
                  },
                  "children": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                },
                "required": ["id", "name", "mode"],
                "additionalProperties": false
              }
            }
          },
          "required": ["schemaVersion", "strategy", "frames"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "schemaVersion": {
              "type": "string",
              "const": "VariableBindingPlan/v1"
            },
            "bindings": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "targetId": {
                    "type": "string",
                    "minLength": 1
                  },
                  "property": {
                    "type": "string",
                    "enum": ["fill", "text", "effect", "spacing", "radius", "stroke", "shadow"]
                  },
                  "source": {
                    "type": "string",
                    "enum": ["variable", "style", "draft-variable", "approved-literal"]
                  },
                  "name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "literalValue": {
                    "anyOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "number"
                      },
                      {
                        "type": "boolean"
                      },
                      {
                        "type": "null"
                      }
                    ]
                  },
                  "approvalRef": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": ["targetId", "property", "source"],
                "additionalProperties": false
              }
            }
          },
          "required": ["schemaVersion", "bindings"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "schemaVersion": {
              "type": "string",
              "const": "DraftComponentPlan/v1"
            },
            "sectionName": {
              "type": "string",
              "const": "Kotikit Draft Components"
            },
            "components": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "reason": {
                    "type": "string",
                    "minLength": 1
                  },
                  "states": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "requiredParts": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                },
                "required": ["id", "name", "reason"],
                "additionalProperties": false
              }
            }
          },
          "required": ["schemaVersion", "sectionName", "components"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "schemaVersion": {
              "type": "string",
              "const": "UIQualityGateReport/v1"
            },
            "status": {
              "type": "string",
              "enum": ["passed", "blocked"]
            },
            "checks": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "status": {
                    "type": "string",
                    "enum": ["passed", "blocked"]
                  },
                  "findings": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                },
                "required": ["id", "name", "status"],
                "additionalProperties": false
              }
            }
          },
          "required": ["schemaVersion", "status", "checks"],
          "additionalProperties": false
        }
      ]
    },
    "filesystemPath": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "id",
    "runId",
    "type",
    "schemaVersion",
    "createdAt",
    "updatedAt",
    "sourceNode",
    "payload"
  ],
  "additionalProperties": false
}
