{
  "name": "kotikit",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "kotikit": "./src/cli.ts",
    "kotikit-mcp": "./src/mcp/server.ts"
  },
  "scripts": {
    "doctor": "bun run src/cli.ts doctor",
    "mcp": "bun run src/mcp/server.ts",
    "bridge": "KOTIKIT_BRIDGE=1 bun run src/mcp/server.ts",
    "prepare": "husky",
    "check": "bun run check:biome && bun run check:spelling",
    "check:biome": "biome check --changed --no-errors-on-unmatched",
    "check:spelling": "bunx --bun cspell . --no-progress",
    "format": "biome check --write .",
    "lint:staged": "lint-staged",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "measure": "bun run scripts/measure-tokens.ts",
    "scaffold:agents": "bun run scripts/scaffold-agents.ts",
    "plugin:build": "cd figma-plugin && bun install && bun run build",
    "plugin:test": "cd figma-plugin && bun test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "zod": "^3.23.0",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/bun": "latest",
    "cspell": "^10.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8"
  },
  "lint-staged": {
    "*.{cjs,js,json,jsonc,md,mjs,ts,tsx}": [
      "biome check --write --no-errors-on-unmatched",
      "bunx --bun cspell --no-progress --no-summary"
    ],
    "*.{css,html,yaml,yml}": [
      "bunx --bun cspell --no-progress --no-summary"
    ]
  }
}
